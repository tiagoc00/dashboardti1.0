rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ────────────────────────────────────────────────
    // Verifica se o usuário está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Extrai o username (parte antes do @) do e-mail do usuário logado
    function username() {
      return request.auth.token.email.split('@')[0].lower();
    }

    // Checks if the user has a document in the 'admins' collection in Firestore
    function isFirestoreAdmin() {
      // The document ID must be the username (part before @)
      return exists(/databases/$(database)/documents/admins/$(username()));
    }

    // Combination: must be authenticated AND have a document in /admins/
    function isAdmin() {
      return isAuth() && isFirestoreAdmin();
    }

    // ─── Coleção: chamados ─────────────────────────────────────────────────
    // Qualquer usuário autenticado pode ler.
    // Somente admins podem criar, atualizar ou deletar.
    match /chamados/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Coleção: satisfacao ───────────────────────────────────────────────
    match /satisfacao/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Coleção: admins ───────────────────────────────────────────────────
    // Somente admins podem ver quem mais é admin ou gerenciar acessos.
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }

    // ─── Bloqueio padrão ──────────────────────────────────────────────────
    // Qualquer outra coleção não mapeada acima é negada por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
